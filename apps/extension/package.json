{
  "name": "extension",
  "version": "1.2.2",
  "private": true,
  "type": "module",
  "scripts": {
    "build:chrome": "dotenv -c -- wxt zip",
    "build:firefox": "dotenv -c -- wxt zip -b firefox",
    "clean": "git clean -xdf build .cache .wxt .turbo node_modules",
    "dev": "dotenv -c -- pnpm dev:chrome",
    "dev:chrome": "wxt",
    "dev:firefox": "wxt -b firefox",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@tailwindcss/vite": "4.2.4",
    "@tanstack/react-query": "catalog:",
    "@tanstack/react-query-devtools": "catalog:",
    "@webext-core/messaging": "2.3.0",
    "@workspace/analytics-extension": "workspace:*",
    "@workspace/api": "workspace:*",
    "@workspace/auth": "workspace:*",
    "@workspace/billing": "workspace:*",
    "@workspace/i18n": "workspace:*",
    "@workspace/monitoring-extension": "workspace:*",
    "@workspace/oxlint": "workspace:*",
    "@workspace/shared": "workspace:*",
    "@workspace/ui": "workspace:*",
    "@workspace/ui-web": "workspace:*",
    "envin": "catalog:",
    "react": "catalog:react19",
    "react-dom": "catalog:react19",
    "sonner": "2.0.7",
    "vite-plugin-svgr": "5.2.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/chrome": "0.1.40",
    "@types/node": "catalog:node24",
    "@types/react": "catalog:react19",
    "@types/react-dom": "catalog:react19",
    "@workspace/tsconfig": "workspace:*",
    "@wxt-dev/auto-icons": "1.1.1",
    "@wxt-dev/module-react": "1.2.2",
    "typescript": "catalog:",
    "wxt": "0.20.25"
  }
}
